<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler"
           resourceType="Unspecified" requireAccess="Script" />
    </handlers>
    <httpPlatform
      processPath="C:\\inetpub\\wwwroot\\OCR-HPuni\\.venv_iis\\Scripts\\python.exe"
      arguments="-m uvicorn api:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT%"
      stdoutLogEnabled="true"
      stdoutLogFile="C:\inetpub\wwwroot\OCR-HPuni\logs\python.log"
      startupTimeLimit="600"
      startupRetryCount="10">
      <environmentVariables>
        <environmentVariable name="APP_CONFIG_PATH" value="C:\inetpub\wwwroot\OCR-HPuni\appsettings.json" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
